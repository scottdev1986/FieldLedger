{
  "name": "fieldledger",
  "private": true,
  "packageManager": "npm@12.0.0",
  "engines": {
    "node": "26.5.0",
    "npm": "12.0.0"
  },
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "dev:api": "dotnet run --project apps/api",
    "dev:seeder": "dotnet run --project apps/seeder",
    "build:dotnet": "dotnet build FieldLedger.slnx"
  }
}
